# Production / Vercel

# Database
# Supabase > Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:<db_password>@db.<project-ref>.supabase.co:5432/postgres

# Server
NODE_ENV=production
PORT=3001

# Auth
# Generate a long random value for production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY=7d

# CORS
# Add your final Vercel domain and any custom domain separated by commas.
# If omitted on Vercel, the app will fall back to VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL.
CORS_ORIGIN=https://your-project.vercel.app,https://your-custom-domain.com

# Frontend API
# Empty for same-origin deploy on Vercel. Keep only if you intentionally call an external API origin.
VITE_API_URL=

# Storage
# Use external storage in production. Local filesystem is not persistent on Vercel.
# Production now fails fast if STORAGE_DRIVER is left as local.
STORAGE_DRIVER=supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=assets

# Optional image processing
IMGLY_API_KEY=
