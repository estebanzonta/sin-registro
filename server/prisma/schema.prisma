generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("customer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart?
  orders    Order[]
}

model Cart {
  id         String     @id @default(uuid())
  userId     String     @unique
  user       User       @relation(fields: [userId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  items      CartItem[]
}

model CartItem {
  id                        String         @id @default(uuid())
  cartId                    String
  cart                      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  customizationMode         String         @default("brand_design")
  garmentModelId            String
  colorId                   String
  sizeId                    String
  printPlacementCode        String
  logoPlacementCode         String
  designId                  String?
  uploadTemplateId          String?
  customDesignUrl           String?
  customAssetUrlsJson       String?
  transferSizeCode          String?
  configurationCode         String         @default("")
  unitPrice                 Float
  quantity                  Int            @default(1)
  layoutSnapshotJson        String?
  configurationSnapshotJson String?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
}

model Category {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  garmentModels GarmentModel[]
}

model GarmentModel {
  id               String               @id @default(uuid())
  categoryId       String
  category         Category             @relation(fields: [categoryId], references: [id])
  name             String
  slug             String               @unique
  description      String?
  basePrice        Float
  active           Boolean              @default(true)
  frontMockupUrl   String?
  backMockupUrl    String?
  sizes            GarmentModelSize[]
  colors           GarmentModelColor[]
  blankStocks      BlankStock[]
  printAreas       PrintArea[]
  orderItems       OrderItem[]
}

model Size {
  id               String               @id @default(uuid())
  name             String               @unique
  garmentModels    GarmentModelSize[]
  blankStocks      BlankStock[]
  orderItems       OrderItem[]
}

model GarmentModelSize {
  id             String       @id @default(uuid())
  garmentModelId String
  garmentModel   GarmentModel @relation(fields: [garmentModelId], references: [id])
  sizeId         String
  size           Size         @relation(fields: [sizeId], references: [id])
  active         Boolean      @default(true)

  @@unique([garmentModelId, sizeId])
}

model Color {
  id             String               @id @default(uuid())
  name           String               @unique
  hex            String
  active         Boolean              @default(true)
  garmentModels  GarmentModelColor[]
  blankStocks    BlankStock[]
  orderItems     OrderItem[]
  brandLogos     BrandLogoColor[]
}

model GarmentModelColor {
  id             String       @id @default(uuid())
  garmentModelId String
  garmentModel   GarmentModel @relation(fields: [garmentModelId], references: [id])
  colorId        String
  color          Color        @relation(fields: [colorId], references: [id])
  frontMockupUrl String?
  backMockupUrl  String?
  active         Boolean      @default(true)

  @@unique([garmentModelId, colorId])
}

model BlankStock {
  id             String       @id @default(uuid())
  garmentModelId String
  garmentModel   GarmentModel @relation(fields: [garmentModelId], references: [id])
  colorId        String
  color          Color        @relation(fields: [colorId], references: [id])
  sizeId         String
  size           Size         @relation(fields: [sizeId], references: [id])
  quantity       Int          @default(0)

  @@unique([garmentModelId, colorId, sizeId])
}

model Placement {
  id           String                   @id @default(uuid())
  code         String                   @unique
  name         String
  kind         String
  surface      String
  active       Boolean                  @default(true)
  printAreas   PrintArea[]
  designRules  DesignPlacement[]
  templates    UploadTemplate[]
  logoRules    BrandLogoPlacement[]
}

model PrintArea {
  id             String       @id @default(uuid())
  garmentModelId String
  garmentModel   GarmentModel @relation(fields: [garmentModelId], references: [id])
  placementId    String
  placement      Placement    @relation(fields: [placementId], references: [id])
  xPct           Float
  yPct           Float
  widthPct       Float
  heightPct      Float
  active         Boolean      @default(true)

  @@unique([garmentModelId, placementId])
}

model DesignCategory {
  id      String   @id @default(uuid())
  name    String
  slug    String   @unique
  code    String   @unique
  active  Boolean  @default(true)
  designs Design[]
}

model Collection {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  type        String
  description String?
  active      Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  designs     Design[]
}

model Design {
  id                String               @id @default(uuid())
  collectionId      String?
  collection        Collection?          @relation(fields: [collectionId], references: [id])
  designCategoryId  String?
  designCategory    DesignCategory?      @relation(fields: [designCategoryId], references: [id])
  name              String
  slug              String               @unique
  code              String               @unique
  description       String?
  imageUrl          String
  active            Boolean              @default(true)
  limited           Boolean              @default(false)
  sortOrder         Int                  @default(0)
  transferSizes     DesignTransferSize[]
  placements        DesignPlacement[]
  orderItems        OrderItem[]
}

model DesignPlacement {
  id          String    @id @default(uuid())
  designId    String
  design      Design    @relation(fields: [designId], references: [id])
  placementId String
  placement   Placement @relation(fields: [placementId], references: [id])

  @@unique([designId, placementId])
}

model DesignTransferSize {
  id          String   @id @default(uuid())
  designId    String
  design      Design   @relation(fields: [designId], references: [id])
  sizeCode    String
  widthCm     Float
  heightCm    Float
  stock       Int      @default(0)
  extraPrice  Float    @default(0)
  active      Boolean  @default(true)

  @@unique([designId, sizeCode])
}

model UploadTemplate {
  id                  String               @id @default(uuid())
  code                String               @unique
  slug                String               @unique
  name                String
  customizationType   String
  description         String?
  requiredImageCount  Int
  allowsText          Boolean              @default(false)
  textLabel           String?
  active              Boolean              @default(true)
  sortOrder           Int                  @default(0)
  placementId         String
  placement           Placement            @relation(fields: [placementId], references: [id])
  previewImageUrl     String?
  sizeOptions         UploadTemplateSize[]
  orderItems          OrderItem[]
}

model UploadTemplateSize {
  id               String         @id @default(uuid())
  uploadTemplateId String
  uploadTemplate   UploadTemplate @relation(fields: [uploadTemplateId], references: [id])
  sizeCode         String
  widthCm          Float
  heightCm         Float
  extraPrice       Float          @default(0)
  active           Boolean        @default(true)

  @@unique([uploadTemplateId, sizeCode])
}

model BrandLogo {
  id         String              @id @default(uuid())
  name       String
  slug       String              @unique
  code       String              @unique
  imageUrl   String
  widthCm    Float
  heightCm   Float
  active     Boolean             @default(true)
  placements BrandLogoPlacement[]
  colors     BrandLogoColor[]
}

model BrandLogoPlacement {
  id          String    @id @default(uuid())
  brandLogoId String
  brandLogo   BrandLogo @relation(fields: [brandLogoId], references: [id])
  placementId String
  placement   Placement @relation(fields: [placementId], references: [id])

  @@unique([brandLogoId, placementId])
}

model BrandLogoColor {
  id          String    @id @default(uuid())
  brandLogoId String
  brandLogo   BrandLogo @relation(fields: [brandLogoId], references: [id])
  colorId     String
  color       Color     @relation(fields: [colorId], references: [id])

  @@unique([brandLogoId, colorId])
}

model Order {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  customerName  String
  customerEmail String
  totalPrice    Float
  status        String      @default("pending")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id                        String         @id @default(uuid())
  orderId                   String
  order                     Order          @relation(fields: [orderId], references: [id])
  garmentModelId            String
  garmentModel              GarmentModel   @relation(fields: [garmentModelId], references: [id])
  colorId                   String
  color                     Color          @relation(fields: [colorId], references: [id])
  sizeId                    String
  size                      Size           @relation(fields: [sizeId], references: [id])
  customizationMode         String         @default("brand_design")
  configurationCode         String         @default("")
  designId                  String?
  design                    Design?        @relation(fields: [designId], references: [id])
  uploadTemplateId          String?
  uploadTemplate            UploadTemplate? @relation(fields: [uploadTemplateId], references: [id])
  customDesignUrl           String?
  customAssetUrlsJson       String?
  transferSizeCode          String?
  mainPlacement             String?
  printPlacementCode        String?
  logoPlacement             String?
  logoPlacementCode         String?
  unitPrice                 Float
  layoutSnapshotJson        String?
  configurationSnapshotJson String?
}
